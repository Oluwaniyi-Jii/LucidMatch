# LucidMatch Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# AI Provider Configuration (choose one)
# =============================================================================

# Option 1: Anthropic Claude (Recommended)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Option 2: OpenAI GPT-4o
# OPENAI_API_KEY=sk-your-key-here

# =============================================================================
# Processing Settings
# =============================================================================

# Minimum match score to show results (0.0-1.0)
CONFIDENCE_THRESHOLD=0.65

# Enable PII stripping for blind evaluation (true/false)
PRIVACY_MODE=true

# Enable bias detection checks (true/false)
BIAS_CHECK_ENABLED=true

# Cache LLM responses for identical inputs (true/false)
CACHE_ENABLED=true
